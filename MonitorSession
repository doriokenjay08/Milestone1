    import java.sql.*;
import java.util.Scanner;

public class MonitorSession {
    public static void record(Connection conn, Scanner sc) throws SQLException {
        System.out.print("Pet ID: ");
        int petId = sc.nextInt();
        sc.nextLine();

        System.out.print("Check-in time: ");
        String in = sc.nextLine();

        System.out.print("Check-out time: ");
        String out = sc.nextLine();

        String sql = "INSERT INTO sessions (pet_id, check_in, check_out) VALUES (?, ?, ?)";
        PreparedStatement pst = conn.prepareStatement(sql);
        pst.setInt(1, petId);
        pst.setString(2, in);
        pst.setString(3, out);
        pst.executeUpdate();

        System.out.println("Session Recorded!");
    }
}